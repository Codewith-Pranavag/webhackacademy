# WebHack Academy — environment template
# Copy to .env.local and adjust as needed.

# Base URL of the WebHack Academy backend API.
# No trailing slash and no /v1 suffix — the client appends the version prefix.
# Production (Railway):
NEXT_PUBLIC_API_URL=https://webhackacademyapi-production.up.railway.app
# Local backend:
# NEXT_PUBLIC_API_URL=http://localhost:3000
