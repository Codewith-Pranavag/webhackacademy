# WebHack Academy API — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# (Design-stage: lives in docs/backend/; moves to the backend repo root at build time.)

# ------------------------------------------------------------------ Core
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# ------------------------------------------------------------------ Database (PostgreSQL)
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webhack?schema=public

# ------------------------------------------------------------------ Auth / JWT
# Generate strong 32+ byte secrets, e.g.  openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ------------------------------------------------------------------ Redis (cache, rate limit, queues, pub/sub)
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------ Object storage (Cloudflare R2 / S3-compatible)
R2_BUCKET=webhack-media
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_REGION=auto
# Public base URL (CDN) for public assets like avatars
R2_PUBLIC_URL=https://cdn.webhackacademy.com

# ------------------------------------------------------------------ Email (SMTP)
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="WebHack Academy <no-reply@webhackacademy.com>"

# ------------------------------------------------------------------ Payments (Stripe)
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ------------------------------------------------------------------ Search (Meilisearch) — optional in dev
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=
